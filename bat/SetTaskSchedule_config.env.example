# タスクスケジューラのタスク名
TASK_NAME=ClaudeMapApp

# claude -p を実行するカレントディレクトリ
# 空欄にすると bat フォルダの2階層上を自動で使用する
# 例: C:\Users\yourname\projects\myapp
CLAUDE_CODE_EXEC_DIR=

# 実行する手順書ファイル名
PROCEDURE_FILE=

# 実行モード（dev=開発, prod=本番）
MODE=dev

# 何分に1回起動するか（分間隔モード）
# 0 にすると SCHEDULE_TIMES の時刻指定モードになる
INTERVAL_MINUTES=10

# 時刻指定モード時の起動時刻（カンマ区切り）
# 例: 09:00,13:00,18:00
SCHEDULE_TIMES=09:00,18:00
